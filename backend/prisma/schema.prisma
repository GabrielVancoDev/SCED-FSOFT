model User {
  id              Int           @id @default(autoincrement()) 

  nome            String
  email           String        @unique
  senha           String

  matricula       String        @unique

  tipoUsuario     TipoUsuario

  ativo           Boolean       @default(true)

  ultimoLogin     DateTime?

  departamentoId  Int?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}