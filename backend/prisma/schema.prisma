generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Departamento {
  id        Int     @id @default(autoincrement())
  nome      String
  sigla     String  @unique
  descricao String?

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios User[]
  documentos Documento[]

}

enum TipoUsuario {
  ADMIN
  COMUM
  ESPECIAL
}

model User {
  id Int @id @default(autoincrement())

  nome  String
  email String @unique
  senha String

  matricula String @unique

  tipoUsuario TipoUsuario

  ativo Boolean @default(true)

  ultimoLogin DateTime?

  departamentoId Int?

  departamento Departamento? @relation(fields: [departamentoId], references: [id])

  documentos Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StatusDocumento {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?

  documentos  Documento[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Documento {
  id                Int      @id @default(autoincrement())

  numeroProtocolo String @unique

  assunto           String
  descricao         String?

  dataEntrada       DateTime @default(now())

  usuarioId         Int
  departamentoId    Int
  statusId          Int

  usuario           User             @relation(fields: [usuarioId], references: [id])
  departamento      Departamento     @relation(fields: [departamentoId], references: [id])
  status            StatusDocumento  @relation(fields: [statusId], references: [id])

  anexos            Anexo[]
  historicos        HistoricoDocumento[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Anexo {
  id              Int      @id @default(autoincrement())

  nomeArquivo     String
  caminhoArquivo  String

  documentoId     Int

  documento Documento @relation(fields: [documentoId], references: [id])

  createdAt DateTime @default(now())
}

model HistoricoDocumento {
  id Int @id @default(autoincrement())

  documentoId Int
  usuarioId Int

  statusAnterior String?
  statusNovo String

  observacao String?

  documento Documento @relation(fields: [documentoId], references: [id])

  usuario User @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
}